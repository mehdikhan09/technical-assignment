@inherits LayoutComponentBase

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudText Typo="Typo.h6">METS — Stock Replenishment</MudText>
        <MudSpacer />
        <MudNavLink Href="/dashboard" Match="NavLinkMatch.All"
                    Style="color:white; margin-right: 16px;">Dashboard</MudNavLink>
        <MudNavLink Href="/requests" Match="NavLinkMatch.All"
                    Style="color:white;">Requests</MudNavLink>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
