@page "/dashboard"
@rendermode InteractiveServer
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Dashboard - Stock Replenishment</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Stock Replenishment Dashboard</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_allRequests is not null)
{
    <!-- Summary Cards -->
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.h3" Color="Color.Primary">@_totalRequests</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Total Requests</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Large" Color="Color.Primary" />
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.h3" Color="Color.Info">@_submittedCount</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Pending Review</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Size="Size.Large" Color="Color.Info" />
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.h3" Color="Color.Success">@_approvedCount</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Approved</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" />
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.h3" Color="Color.Secondary">@_fulfilledCount</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Fulfilled</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.Done" Size="Size.Large" Color="Color.Secondary" />
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <!-- Priority Distribution -->
    <MudGrid Class="mb-6">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Priority Distribution</MudText>
                <MudGrid>
                    <MudItem xs="4">
                        <MudText Typo="Typo.h5" Color="Color.Error">@_urgentCount</MudText>
                        <MudText Typo="Typo.body2">Urgent</MudText>
                    </MudItem>
                    <MudItem xs="4">
                        <MudText Typo="Typo.h5" Color="Color.Warning">@_normalCount</MudText>
                        <MudText Typo="Typo.body2">Normal</MudText>
                    </MudItem>
                    <MudItem xs="4">
                        <MudText Typo="Typo.h5" Color="Color.Success">@_lowCount</MudText>
                        <MudText Typo="Typo.body2">Low</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Stock Check Status</MudText>
                <MudGrid>
                    <MudItem xs="4">
                        <MudText Typo="Typo.h5" Color="Color.Success">@_stockCheckPassedCount</MudText>
                        <MudText Typo="Typo.body2">✅ Passed</MudText>
                    </MudItem>
                    <MudItem xs="4">
                        <MudText Typo="Typo.h5" Color="Color.Error">@_stockCheckFailedCount</MudText>
                        <MudText Typo="Typo.body2">❌ Failed</MudText>
                    </MudItem>
                    <MudItem xs="4">
                        <MudText Typo="Typo.h5" Color="Color.Info">@_stockCheckPendingCount</MudText>
                        <MudText Typo="Typo.body2">⏳ Pending</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Recent Requests -->
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
            <MudText Typo="Typo.h6">Recent Requests</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Text" Color="Color.Primary" 
                       Href="/requests" EndIcon="@Icons.Material.Filled.ArrowForward">
                View All
            </MudButton>
        </MudStack>

        <MudTable Items="_recentRequests" Hover="true" Dense="true" T="RequestSummaryDto"
                  OnRowClick="@(args => Nav.NavigateTo($"/requests/{args.Item.Id}"))">
            <HeaderContent>
                <MudTh>Request #</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Priority</MudTh>
                <MudTh>Location</MudTh>
                <MudTh>Created By</MudTh>
                <MudTh>Created</MudTh>
                <MudTh>Items</MudTh>
                <MudTh>Stock Check</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Request #">@context.RequestNumber</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@StatusColor(context.Status)" Size="Size.Small">
                        @context.Status
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Priority">
                    <MudChip T="string" Color="@PriorityColor(context.Priority)" Size="Size.Small">
                        @context.Priority
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Location">@context.LocationCode</MudTd>
                <MudTd DataLabel="Created By">@context.CreatedBy</MudTd>
                <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("dd MMM HH:mm")</MudTd>
                <MudTd DataLabel="Items">@context.LineItemCount</MudTd>
                <MudTd DataLabel="Stock Check">@StockCheckLabel(context.StockCheckPassed)</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

    <!-- Requests by Status -->
    <MudGrid Class="mb-4">
        @if (_draftRequests.Any())
        {
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" /> 
                        Draft Requests (@_draftRequests.Count)
                    </MudText>
                    <MudList T="string" Dense="true">
                        @foreach (var req in _draftRequests.Take(5))
                        {
                            <MudListItem T="string" OnClick="@(() => Nav.NavigateTo($"/requests/{req.Id}"))">
                                <div class="d-flex justify-space-between align-center">
                                    <div>
                                        <MudText Typo="Typo.body2"><b>@req.RequestNumber</b> - @req.LocationCode</MudText>
                                        <MudText Typo="Typo.caption">@req.CreatedBy • @req.LineItemCount items</MudText>
                                    </div>
                                    <MudChip T="string" Color="@PriorityColor(req.Priority)" Size="Size.Small">
                                        @req.Priority
                                    </MudChip>
                                </div>
                            </MudListItem>
                            <MudDivider />
                        }
                    </MudList>
                </MudPaper>
            </MudItem>
        }

        @if (_submittedRequests.Any())
        {
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" /> 
                        Pending Review (@_submittedRequests.Count)
                    </MudText>
                    <MudList T="string" Dense="true">
                        @foreach (var req in _submittedRequests.Take(5))
                        {
                            <MudListItem T="string" OnClick="@(() => Nav.NavigateTo($"/requests/{req.Id}"))">
                                <div class="d-flex justify-space-between align-center">
                                    <div>
                                        <MudText Typo="Typo.body2"><b>@req.RequestNumber</b> - @req.LocationCode</MudText>
                                        <MudText Typo="Typo.caption">
                                            @req.CreatedBy • @StockCheckLabel(req.StockCheckPassed)
                                        </MudText>
                                    </div>
                                    <MudChip T="string" Color="@PriorityColor(req.Priority)" Size="Size.Small">
                                        @req.Priority
                                    </MudChip>
                                </div>
                            </MudListItem>
                            <MudDivider />
                        }
                    </MudList>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    <!-- Quick Actions -->
    <MudPaper Class="pa-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-3">Quick Actions</MudText>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                       StartIcon="@Icons.Material.Filled.Add" Href="/requests/create">
                Create New Request
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" 
                       StartIcon="@Icons.Material.Filled.List" Href="/requests">
                View All Requests
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Info" 
                       StartIcon="@Icons.Material.Filled.FilterList" 
                       Href="/requests?status=Submitted">
                Review Pending
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Success" 
                       StartIcon="@Icons.Material.Filled.CheckCircle" 
                       Href="/requests?status=Approved">
                View Approved
            </MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    private List<RequestSummaryDto> _allRequests = new();
    private List<RequestSummaryDto> _recentRequests = new();
    private List<RequestSummaryDto> _draftRequests = new();
    private List<RequestSummaryDto> _submittedRequests = new();
    private bool _loading = true;

    // Statistics
    private int _totalRequests;
    private int _submittedCount;
    private int _approvedCount;
    private int _fulfilledCount;
    private int _urgentCount;
    private int _normalCount;
    private int _lowCount;
    private int _stockCheckPassedCount;
    private int _stockCheckFailedCount;
    private int _stockCheckPendingCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardDataAsync();
    }

    private async Task LoadDashboardDataAsync()
    {
        _loading = true;

        try
        {
            // Fetch all requests (using a large page size to get all)
            var result = await Api.GetRequestsAsync(null, null, null, page: 1, pageSize: 100);

            if (result is not null)
            {
                _allRequests = result.Items;

                // Calculate statistics
                _totalRequests = _allRequests.Count;
                _submittedCount = _allRequests.Count(r => r.Status == "Submitted");
                _approvedCount = _allRequests.Count(r => r.Status == "Approved");
                _fulfilledCount = _allRequests.Count(r => r.Status == "Fulfilled");

                _urgentCount = _allRequests.Count(r => r.Priority == "Urgent");
                _normalCount = _allRequests.Count(r => r.Priority == "Normal");
                _lowCount = _allRequests.Count(r => r.Priority == "Low");

                _stockCheckPassedCount = _allRequests.Count(r => r.StockCheckPassed == true);
                _stockCheckFailedCount = _allRequests.Count(r => r.StockCheckPassed == false);
                _stockCheckPendingCount = _allRequests.Count(r => r.StockCheckPassed == null && r.Status != "Draft");

                // Get recent requests (last 10)
                _recentRequests = _allRequests
                    .OrderByDescending(r => r.CreatedAt)
                    .Take(10)
                    .ToList();

                // Get requests by status
                _draftRequests = _allRequests
                    .Where(r => r.Status == "Draft")
                    .OrderByDescending(r => r.CreatedAt)
                    .ToList();

                _submittedRequests = _allRequests
                    .Where(r => r.Status == "Submitted")
                    .OrderByDescending(r => r.CreatedAt)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private static Color StatusColor(string status) => status switch
    {
        "Draft"     => Color.Default,
        "Submitted" => Color.Info,
        "Approved"  => Color.Success,
        "Rejected"  => Color.Error,
        "Fulfilled" => Color.Secondary,
        _           => Color.Default
    };

    private static Color PriorityColor(string priority) => priority switch
    {
        "Urgent" => Color.Error,
        "Normal" => Color.Warning,
        "Low"    => Color.Success,
        _        => Color.Default
    };

    private static string StockCheckLabel(bool? passed) => passed switch
    {
        true  => "✅ Passed",
        false => "❌ Failed",
        null  => "⏳ Pending"
    };
}
